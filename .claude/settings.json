{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/inject-repo-artifacts-as-data.js\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/inject-repo-artifacts-as-data.js\""
          }
        ]
      }
    ]
  },
  "claudeMdExcludes": [
    "**/oleg-agent-skills/*/**/CLAUDE.md",
    "**/oleg-agent-skills/*/**/CLAUDE.local.md",
    "**/oleg-agent-skills/*/**/.claude/rules/**"
  ]
}
